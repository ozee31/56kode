---
import { SITE } from "@config";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import Footer from "@components/Footer.astro";
import Header from "@components/Header.astro";
import Layout from "./Layout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout
  title={`${frontmatter.title} | ${SITE.title}`}
  description="Flavien Beninca — developer exploring AI agents, LLMs, and AI-assisted development, with 15+ years of frontend expertise in React and TypeScript."
>
  <Header activeNav="about" />
  <Breadcrumbs />
  <main id="main-content">
    <section id="about" class="prose mb-28 max-w-3xl prose-img:border-0">
      <div class="not-prose mb-8 flex flex-col items-center gap-5 text-foreground sm:flex-row sm:items-start">
        <img
          src="/assets/avatar.png"
          alt="Flavien Beninca"
          width="120"
          height="120"
          class="h-30 w-30 shrink-0 rounded-full border-2 border-accent object-cover aspect-square"
        />
        <div>
          <h1 class="text-2xl font-bold tracking-wider sm:text-3xl">
            Flavien Beninca
          </h1>
          <p class="mt-1 text-sm opacity-80">Lead Frontend Developer</p>
          <p class="mt-2">
            Developer with over 15 years of experience, exploring AI agents,
            LLMs, and AI-assisted development.
          </p>
        </div>
      </div>
      <slot />
    </section>
  </main>
  <Footer />
</Layout>
