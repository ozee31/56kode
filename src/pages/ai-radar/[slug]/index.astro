---
import { type CollectionEntry, getCollection } from "astro:content";
import AiRadarPost from "@layouts/AiRadarPost.astro";
import AiRadarDetails from "@layouts/AiRadarDetails.astro";
import getSortedPosts from "@utils/getSortedPosts";
import getPageNumbers from "@utils/getPageNumbers";
import getPagination from "@utils/getPagination";

export interface Props {
  post: CollectionEntry<"aiRadar">;
}

export async function getStaticPaths() {
  const posts = await getCollection("aiRadar");

  const postResult = posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));

  const pagePaths = getPageNumbers(posts.length).map(pageNum => ({
    params: { slug: String(pageNum) },
  }));

  return [...postResult, ...pagePaths];
}

const { slug } = Astro.params;
const { post } = Astro.props;

const posts = await getCollection("aiRadar");
const sortedPosts = getSortedPosts(posts) as CollectionEntry<"aiRadar">[];
const pagination = getPagination({ posts: sortedPosts, page: slug });
---

{post ? <AiRadarDetails post={post} /> : <AiRadarPost {...pagination} />}
