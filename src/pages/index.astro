---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE, SOCIALS } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => (data as any).featured);
const recentPosts = sortedPosts.filter(({ data }) => !(data as any).featured);

const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <div class="hero-content">
        <div class="hero-avatar shrink-0">
          <img
            src="/assets/avatar.png"
            alt="Flavien Beninca"
            width="112"
            height="112"
            class="avatar-img aspect-square h-28 w-28 shrink-0 rounded-full border-2 border-accent object-cover"
          />
        </div>
        <div class="hero-text">
          <h1>
            Flavien Beninca<br /><span class="text-xl"
              >Lead Frontend Developer</span
            >
          </h1>
          <p>
            From 15+ years of frontend development to the frontier of AI agents
            and LLMs — this blog covers AI-assisted development, React,
            TypeScript, and the tools shaping how we build software today.
          </p>
          <div class="hero-links">
            <a
              target="_blank"
              href="/rss.xml"
              class="rss-link"
              aria-label="rss feed"
              title="RSS Feed"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon"
                ><path
                  d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"
                ></path><path
                  d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"
                ></path><circle cx="6" cy="18" r="2"></circle>
              </svg>
              <span class="sr-only">RSS Feed</span>
            </a>
            {socialCount > 0 && <Socials />}
          </div>
        </div>
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section id="featured">
          <h2>Featured</h2>
          <ul>
            {featuredPosts.map(({ data, id }) => (
              <Card
                href={`/posts/${id}/`}
                frontmatter={data as any}
                secHeading={false}
              />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>Recent Posts</h2>
          <ul>
            {recentPosts.map(
              ({ data, id }, index) =>
                index < SITE.postPerIndex && (
                  <Card
                    href={`/posts/${id}/`}
                    frontmatter={data as any}
                    secHeading={false}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    <div class="all-posts-btn-wrapper">
      <LinkButton href="/posts/">
        All Posts
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @reference "../styles/theme.css";
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  .hero-content {
    @apply flex flex-col items-center gap-5 text-center;
  }
  .avatar-img {
    @apply h-28 w-28 shrink-0 rounded-full border-2 border-accent object-cover aspect-square;
  }
  #hero h1 {
    @apply my-2 inline-block text-3xl font-bold;
  }
  #hero .rss-icon {
    @apply h-6 w-6 scale-110 fill-accent;
  }
  #hero p {
    @apply my-2;
  }
  .hero-links {
    @apply mt-3 flex items-center gap-1;
  }

  @media (width >= 640px) {
    .hero-content {
      @apply flex-row items-start text-left;
    }
    .avatar-img {
      @apply mt-2;
    }
    #hero h1 {
      @apply my-2 text-5xl;
    }
    #hero .rss-icon {
      @apply scale-125;
    }
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts {
    @apply pb-6 pt-6;
  }
  #featured h2,
  #recent-posts h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .all-posts-btn-wrapper {
    @apply my-8 text-center;
  }
</style>
