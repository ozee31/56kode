---
export interface Props {
  tag: string;
  size?: "sm" | "lg";
}

const { tag, size = "sm" } = Astro.props;
---

<li class="inline-block">
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-block rounded-full border border-border bg-card/40 transition-colors hover:border-accent/40 hover:bg-accent/15 hover:text-accent",
      size === "sm" ? "px-2.5 py-0.5 text-xs" : "px-3 py-1 text-sm",
    ]}
  >
    {tag}
  </a>
</li>
